{
  "name": "@prefactor/sdk-workspace",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "docs:typedoc": "typedoc --options typedoc.json",
    "versions:check": "bun run scripts/generate-versions.ts --check",
    "release:cli:stable": "bun run scripts/release-cli-stable.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "example:langchain": "bun examples/langchain/simple-agent.ts",
    "example:livekit": "bun examples/livekit/simple-session.ts",
    "example:ai": "bun examples/ai-sdk/simple-agent.ts",
    "example:ai-schema": "bun examples/ai-sdk/custom-schema.ts"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@biomejs/biome": "2.3.11",
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@livekit/agents": "^1.0.0",
    "@prefactor/ai": "workspace:*",
    "@prefactor/claude": "workspace:*",
    "@prefactor/core": "workspace:*",
    "@prefactor/livekit": "workspace:*",
    "@prefactor/langchain": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/node": "^20.19.37",
    "ai": "^6.0.116",
    "bun-types": "latest",
    "langchain": "^1.2.31",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
